// --- IP-range checks -----------------------------------------------------

function ipv6CompareNorm(addr: string): string {
    // Normalize an IPv6 literal for prefix comparison: lowercase + expand.
    // We accept addr as-is; matching against blocked CIDRs is by parsing.
    return addr.toLowerCase();
}

function ipv4ToInt(addr: string): number | null {
    const parts = addr.split(".");
    if (parts.length !== 4) return null;
    let n = 0;
    for (const p of parts) {
        if (!/^\d+$/.test(p)) return null;
        const v = Number(p);
        if (v < 0 || v > 255) return null;
        n = (n * 256) + v;
    }
    return n;
}

function ipv6Expand(addr: string): number[] | null {
    // Returns 8 16-bit groups, or null on parse failure.
    // Strip trailing zone-id (RFC 6874 — `%eth0`).
    let stripped = addr;
    const pct = stripped.indexOf("%");
    if (pct >= 0) stripped = stripped.slice(0, pct);
    // Embedded IPv4 (e.g., ::ffff:127.0.0.1) → expand.
    const lastColon = stripped.lastIndexOf(":");
    if (lastColon >= 0 && stripped.includes(".", lastColon)) {
        const v4 = ipv4ToInt(stripped.slice(lastColon + 1));
        if (v4 === null) return null;
        const high = ((v4 >>> 16) & 0xffff).toString(16);
        const low = (v4 & 0xffff).toString(16);
        stripped = stripped.slice(0, lastColon + 1) + high + ":" + low;
    }
    let head: string[];
    let tail: string[];
    if (stripped.includes("::")) {
        const [h, t] = stripped.split("::", 2);
        head = h ? h.split(":") : [];
        tail = t ? t.split(":") : [];
        const fill = 8 - head.length - tail.length;
        if (fill < 0) return null;
        head = head.concat(new Array(fill).fill("0"));
    } else {
        head = stripped.split(":");
        tail = [];
    }
    const groups = head.concat(tail);
    if (groups.length !== 8) return null;
    const out: number[] = [];
    for (const g of groups) {
        if (!/^[0-9a-fA-F]{1,4}$/.test(g)) return null;
        out.push(parseInt(g, 16));
    }
    return out;
}

function ipv6InNetwork(addr: string, network: string): boolean {
    // network: "<addr>/<prefix>"
    const [netAddr, prefixStr] = network.split("/");
    const prefix = Number(prefixStr);
    const a = ipv6Expand(addr);
    const n = ipv6Expand(netAddr);
    if (!a || !n) return false;
    let bits = prefix;
    for (let i = 0; i < 8 && bits > 0; i++) {
        const groupBits = Math.min(16, bits);
        const mask = groupBits === 16 ? 0xffff : (0xffff << (16 - groupBits)) & 0xffff;
        if ((a[i] & mask) !== (n[i] & mask)) return false;
        bits -= groupBits;
    }
    return true;
}

function isIpv6Blocked(bracketedHost: string): boolean {
    if (!bracketedHost.startsWith("[") || !bracketedHost.endsWith("]")) return false;
    const inner = bracketedHost.slice(1, -1);
    if (!ipv6Expand(inner)) {
        // Malformed inside brackets — fail-closed.
        return true;
    }
    for (const net of BLOCKED_IPV6_NETWORKS) {
        if (ipv6InNetwork(inner, net)) return true;
    }
    return false;
}

function isIpv4LiteralBlocked(host: string): { blocked: boolean; reason: string } {
    const n = ipv4ToInt(host);
    if (n === null) return { blocked: false, reason: "" };
    // JS bitwise ops produce signed int32. For ranges in 0x80000000..0xffffffff
    // (172.16, 192.168, 169.254, 224, 240) the comparison silently fails
    // because 0xc0a80000 etc. are positive Numbers but `n & mask` is negative
    // int32. `>>> 0` converts to unsigned-32 for proper comparison.
    const masked = (mask: number): number => (n & mask) >>> 0;
    // 127.0.0.0/8 loopback
    if (masked(0xff000000) === 0x7f000000) {
        return { blocked: true, reason: `IP ${host} is loopback` };
    }
    // 10.0.0.0/8 private
    if (masked(0xff000000) === 0x0a000000) {
        return { blocked: true, reason: `IP ${host} is in a private range` };
    }
    // 172.16.0.0/12 private
    if (masked(0xfff00000) === 0xac100000) {
        return { blocked: true, reason: `IP ${host} is in a private range` };
    }
    // 192.168.0.0/16 private
    if (masked(0xffff0000) === 0xc0a80000) {
        return { blocked: true, reason: `IP ${host} is in a private range` };
    }
    // 169.254.0.0/16 link-local (incl. AWS IMDS 169.254.169.254)
    if (masked(0xffff0000) === 0xa9fe0000) {
        if (host === "169.254.169.254") {
            return { blocked: true, reason: "IP 169.254.169.254 is the AWS IMDS metadata endpoint" };
        }
        return { blocked: true, reason: `IP ${host} is link-local` };
    }
    // 224.0.0.0/4 multicast
    if (masked(0xf0000000) === 0xe0000000) {
        return { blocked: true, reason: `IP ${host} is multicast` };
    }
    // 0.0.0.0/8 unspecified / reserved
    if (masked(0xff000000) === 0x00000000) {
        return { blocked: true, reason: `IP ${host} is unspecified (0.0.0.0 / ::)` };
    }
    // 100.64.0.0/10 CGNAT (reserved per RFC 6598)
    if (masked(0xffc00000) === 0x64400000) {
        return { blocked: true, reason: `IP ${host} is reserved` };
    }
    // 240.0.0.0/4 reserved
    if (masked(0xf0000000) === 0xf0000000) {
        return { blocked: true, reason: `IP ${host} is reserved` };
    }
    return { blocked: false, reason: "" };
}

function coerceIpv4Obfuscation(host: string): string | null {
    if (!host || host.includes(".") || host.includes(":")) return null;
    const s = host.toLowerCase();
    let n: number;
    if (s.startsWith("0x")) {
        const m = s.slice(2);
        if (!/^[0-9a-f]+$/.test(m)) return null;
        n = parseInt(m, 16);
    } else if (s.startsWith("0") && s.length > 1 && /^[0-7]+$/.test(s)) {
        n = parseInt(s, 8);
    } else if (/^\d+$/.test(s)) {
        n = parseInt(s, 10);
    } else {
        return null;
    }
    if (!Number.isFinite(n) || n < 0 || n > 0xffffffff) return null;
    const a = (n >>> 24) & 0xff;
    const b = (n >>> 16) & 0xff;
    const c = (n >>> 8) & 0xff;
    const d = n & 0xff;
    return `${a}.${b}.${c}.${d}`;
}

// --- Path validation -----------------------------------------------------

function validatePath(path: string): { ok: boolean; detail: string } {
    if (!path) return { ok: true, detail: "" };
    for (const ch of PATH_FORBIDDEN_BYTES) {
        if (path.includes(ch)) {
            const code = ch.codePointAt(0)!.toString(16).padStart(2, "0").toUpperCase();
            return { ok: false, detail: `path contains forbidden control byte (0x${code})` };
        }
    }
    for (const ch of PATH_CONTROL_CHARS) {
        if (path.includes(ch)) {
            const code = ch.codePointAt(0)!.toString(16).padStart(4, "0").toUpperCase();
            return { ok: false, detail: `path contains bidi/RTL control char (U+${code})` };
        }
    }
    if (PATH_TRAVERSAL_RE.test(path)) {
        return {
            ok: false,
            detail: "path contains traversal pattern (.., ./, //, %2e%2e, .%2e, %2e., %2f, or %00)",
        };
    }
    return { ok: true, detail: "" };
}

// --- IDN normalization ---------------------------------------------------

function idnaNormalize(host: string): string {
    let h = host;
    if (h.endsWith(".")) h = h.slice(0, -1);
    // The native URL constructor IDN-normalizes hostname for us when parsing,
    // but we re-lowercase here so callers passing host through directly still
    // produce parity output.
    return h.toLowerCase();
}

// --- Allowlist load + match ---------------------------------------------

export function loadAllowlist(raw: { providers?: Allowlist }): Allowlist {
    const providers = (raw && raw.providers) || {};
    if (typeof providers !== "object" || Array.isArray(providers)) {
        throw new Error("allowlist: top-level `providers` must be a mapping");
    }
    return providers as Allowlist;
}

function coercePort(p: unknown): number | null {
    // `typeof p === "number"` excludes booleans (bool is its own typeof in JS),
    // so unlike Python's _coerce_port we don't need a separate bool guard. The
    // remaining defenses: integer-only and 1..65535 range.
    if (typeof p !== "number") return null;
    if (!Number.isInteger(p)) return null;
    if (p < 1 || p > 65535) return null;
    return p;
}

function providerForHost(
    host: string,
    allowlist: Allowlist
): { providerId: string | null; allowedPorts: number[] } {
    for (const [providerId, entries] of Object.entries(allowlist)) {
        if (!Array.isArray(entries)) continue;
        for (const entry of entries) {
            if (!entry || typeof entry !== "object") continue;
            const entryHost = String(entry.host || "").toLowerCase();
            if (entryHost === host) {
                const rawPorts = Array.isArray(entry.ports) ? entry.ports : [];
                const validPorts: number[] = [];
                for (const p of rawPorts) {
                    const c = coercePort(p);
                    if (c !== null) validPorts.push(c);
                }
                return { providerId, allowedPorts: validPorts };
            }
        }
    }
    return { providerId: null, allowedPorts: [] };
}

// --- Authority extraction + pre-parse defense ----------------------------

function extractAuthority(url: string): string | null {
    const schemeEnd = url.indexOf("://");
    if (schemeEnd < 0) return null;
    const start = schemeEnd + 3;
    let end = url.length;
    for (const ch of ["/", "?", "#"]) {
        const idx = url.indexOf(ch, start);
        if (idx >= 0 && idx < end) end = idx;
    }
    return url.slice(start, end);
}

function hasObfuscatedIpv4Octet(authority: string): boolean {
    let host = authority.split("@").pop() || "";
    if (host.startsWith("[")) return false;
    const colon = host.lastIndexOf(":");
    if (colon >= 0) host = host.slice(0, colon);
    const parts = host.split(".");
    if (parts.length !== 4) return false;
    let obfuscated = false;
    for (const p of parts) {
        if (!p) return false;
        const lower = p.toLowerCase();
        if (p.length > 1 && p.startsWith("0") && !lower.startsWith("0x")) {
            obfuscated = true;
        } else if (lower.startsWith("0x")) {
            obfuscated = true;
        } else if (!/^\d+$/.test(p)) {
            return false;
        }
    }
    return obfuscated;
}

function validateAuthority(url: string): { ok: boolean; code: string; detail: string } {
    const authority = extractAuthority(url);
    if (authority === null) return { ok: true, code: "", detail: "" };
    // Carve out bracketed IPv6 (`%` inside brackets is the RFC 6874 zone-id
    // marker and must be allowed). Mirrors Python's logic.
    let outsideBrackets = authority;
    if (authority.startsWith("[")) {
        const close = authority.indexOf("]");
        if (close >= 0) outsideBrackets = authority.slice(0, 1) + authority.slice(close);
    }
    for (const ch of AUTHORITY_FORBIDDEN_CHARS) {
        if (outsideBrackets.includes(ch)) {
            const cp = ch.codePointAt(0)!.toString(16).padStart(4, "0").toUpperCase();
            return {
                ok: false,
                code: "ENDPOINT-PARSE-FAILED",
                detail:
                    `authority contains forbidden character (U+${cp}); ` +
                    "percent-encoding, backslashes, Unicode dot equivalents, " +
                    "and zero-width / bidi controls are all rejected",
            };
        }
    }
    if (hasObfuscatedIpv4Octet(authority)) {
        return {
            ok: false,
            code: "ENDPOINT-IP-BLOCKED",
            detail: `obfuscated IPv4 octet in authority '${authority}'; use plain dotted-quad`,
        };
    }
    return { ok: true, code: "", detail: "" };
}

// --- Reject helper -------------------------------------------------------

function reject(url: string, code: string, detail: string): ValidationResult {
    return { valid: false, url, code, detail };
}

// --- Public entry --------------------------------------------------------

export function validate(url: string, allowlist: Allowlist): ValidationResult {
    if (typeof url !== "string") {
        return reject(String(url), "ENDPOINT-PARSE-FAILED", "url must be a string");
    }

    // Step 0: raw control-byte gate (cypherpunk HIGH 2 — pre-parse defense).
    for (const ch of PATH_FORBIDDEN_BYTES) {
        if (url.includes(ch)) {
            const code = ch.codePointAt(0)!.toString(16).padStart(2, "0").toUpperCase();
            return reject(
                url,
                "ENDPOINT-PATH-INVALID",
                `URL contains forbidden control byte (0x${code}); ` +
                "CR/LF/TAB/NUL trigger HTTP smuggling in some clients",
            );
        }
    }

    // Step 0.5: pre-parse authority gate (sprint-1E.c.1 review remediation).
    // Catches the percent-encoded / Unicode-dot / backslash / obfuscated-IPv4
    // bypasses where URL constructor and urlsplit normalize differently.
    const authCheck = validateAuthority(url);
    if (!authCheck.ok) {
        return reject(url, authCheck.code, authCheck.detail);
    }

    // Step 1: parse via native URL.
    // gp HIGH 1: URL constructor in some Node versions throws on RFC 6874
    // zone-id syntax `[addr%25zone]`. Python's urlsplit accepts it. To match
    // Python, we detect the bracketed-IPv6-with-zone-id form, capture it
    // before parsing, strip the zone-id for URL ctor, and route through the
    // IPv6 blocked-range check using the original (zone-stripped) literal.
    let urlForParser = url;
    let zoneStrippedHost: string | null = null;
    {
        const m = url.match(/\[([^\]]*?)%25[^\]]*\]/);
        if (m) {
            zoneStrippedHost = m[1];
            urlForParser = url.replace(/\[([^\]]*?)%25[^\]]*\]/, `[${zoneStrippedHost}]`);
        }
    }
    let parts: URL;
    try {
        parts = new URL(urlForParser);
    } catch {
        // Distinguish "looks relative" from "syntactically broken".
        if (url.startsWith("/") || url === "" || url.startsWith("https:///")) {
            return reject(url, "ENDPOINT-RELATIVE", "missing scheme + netloc");
        }
        if (url.includes("[") && url.split("[").length !== url.split("]").length) {
            return reject(url, "ENDPOINT-PARSE-FAILED", "unmatched IPv6 brackets");
        }
        return reject(url, "ENDPOINT-PARSE-FAILED", "URL constructor raised");
    }

    // Step 2: scheme must be https.
    if (parts.protocol.toLowerCase() !== "https:") {
        const s = parts.protocol.replace(/:$/, "");
        return reject(
            url,
            "ENDPOINT-INSECURE-SCHEME",
            `scheme '${s}' not allowed; only https`,
        );
    }

    // Step 2.5: userinfo reject.
    if (parts.username || parts.password) {
        return reject(
            url,
            "ENDPOINT-USERINFO-PRESENT",
            "URL contains userinfo segment; credentials must travel via env vars, not URLs",
        );
    }

    // Step 3: netloc / hostname must be present.
    if (!parts.host || !parts.hostname) {
        return reject(url, "ENDPOINT-RELATIVE", "URL has no netloc (host)");
    }

    // For IPv6, parts.hostname includes brackets when accessed via the original
    // host, but URL.hostname strips them. Reconstruct the bracketed form for
    // the IPv6 check.
    const rawHostname = parts.hostname;
    const bracketed = rawHostname.includes(":") || parts.host.startsWith("[")
        ? `[${rawHostname.replace(/^\[|\]$/g, "")}]`
        : null;

    // Step 4: IPv6 blocked-range check.
    if (bracketed) {
        if (isIpv6Blocked(bracketed)) {
            return reject(
                url,
                "ENDPOINT-IPV6-BLOCKED",
                `IPv6 literal ${rawHostname} falls in a blocked range`,
            );
        }
        // Public IPv6 falls through to step 8 with ENDPOINT-IPV6-NOT-ALLOWED.
    }

    // IPv4 literal blocking — defense in depth.
    const v4Result = isIpv4LiteralBlocked(rawHostname);
    if (v4Result.blocked) {
        return reject(url, "ENDPOINT-IP-BLOCKED", v4Result.reason || `IP ${rawHostname} is blocked`);
    }
    const coerced = coerceIpv4Obfuscation(rawHostname);
    if (coerced !== null) {
        const c = isIpv4LiteralBlocked(coerced);
        if (c.blocked) {
            return reject(
                url,
                "ENDPOINT-IP-BLOCKED",
                `obfuscated IPv4 literal '${rawHostname}' resolves to ${coerced} (${c.reason})`,
            );
        }
        return reject(
            url,
            "ENDPOINT-IP-BLOCKED",
            `obfuscated IPv4 form '${rawHostname}' not allowed; use dotted-quad`,
        );
    }

    // Step 5: IDN normalization (URL.hostname is already IDNA-2008 encoded).
    const normalizedHost = idnaNormalize(rawHostname);

    // Step 6: port — URL.port is "" for default 443.
    const port = parts.port ? Number(parts.port) : 443;
    if (!Number.isInteger(port) || port < 1 || port > 65535) {
        return reject(url, "ENDPOINT-PARSE-FAILED", "port is not a valid integer");
    }

    // Step 7: path normalization.
    // The URL constructor normalizes `..` segments in pathname (resolves them
    // against the base path), so `https://h/v1/../admin` becomes pathname=
    // "/admin" and the traversal pattern is invisible by the time we run the
    // regex against pathname. Extract the RAW path from the original URL
    // string to preserve the operator-supplied traversal markers.
    const rawPath = (() => {
        // Strip scheme + authority; what remains starts with the path. We
        // use a manual scan rather than regex to avoid catastrophic
        // backtracking on adversarial input.
        const schemeEnd = url.indexOf("://");
        if (schemeEnd < 0) return parts.pathname;
        let pos = schemeEnd + 3;
        // Skip the authority (everything up to next `/`, `?`, `#`, or EOS).
        while (pos < url.length) {
            const ch = url.charCodeAt(pos);
            if (ch === 0x2f /* / */ || ch === 0x3f /* ? */ || ch === 0x23 /* # */) break;
            pos++;
        }
        if (pos >= url.length) return "";
        // Path runs until the first `?` or `#` or EOS.
        const queryStart = url.indexOf("?", pos);
        const fragStart = url.indexOf("#", pos);
        let pathEnd = url.length;
        if (queryStart >= 0) pathEnd = Math.min(pathEnd, queryStart);
        if (fragStart >= 0) pathEnd = Math.min(pathEnd, fragStart);
        return url.slice(pos, pathEnd);
    })();
    const pathOk = validatePath(rawPath);
    if (!pathOk.ok) {
        return reject(url, "ENDPOINT-PATH-INVALID", pathOk.detail);
    }

    // Step 8: explicit host + port allowlist match.
    const { providerId, allowedPorts } = providerForHost(normalizedHost, allowlist);
    if (providerId === null) {
        if (bracketed) {
            return reject(
                url,
                "ENDPOINT-IPV6-NOT-ALLOWED",
                `IPv6 literal ${rawHostname} not in any provider's allowlist; ` +
                "Sprint 1E.b allowlist is hostname-only",
            );
        }
        const isIdn = [...rawHostname].some((c) => c.codePointAt(0)! >= 128) ||
            rawHostname.toLowerCase().startsWith("xn--");
        if (isIdn) {
            return reject(
                url,
                "ENDPOINT-IDN-NOT-ALLOWED",
                `IDN-encoded host '${normalizedHost}' not in any provider's allowlist`,
            );
        }
        return reject(
            url,
            "ENDPOINT-NOT-ALLOWED",
            `host '${normalizedHost}' not in any provider's allowlist`,
        );
    }
    if (allowedPorts.length === 0) {
        return reject(
            url,
            "ENDPOINT-PORT-NOT-ALLOWED",
            `provider '${providerId}' has no valid ports configured (allowlist bug?)`,
        );
    }
    if (!allowedPorts.includes(port)) {
        return reject(
            url,
            "ENDPOINT-PORT-NOT-ALLOWED",
            `port ${port} not in allowlist [${allowedPorts.join(", ")}] for provider '${providerId}'`,
        );
    }

    return {
        valid: true,
        url,
        scheme: "https",
        host: normalizedHost,
        port,
        // Use the raw path (NOT parts.pathname) so bare-host URLs return ""
        // instead of "/" — matches Python's urlsplit behavior for parity.
        path: rawPath,
        matched_provider: providerId,
    };
}
