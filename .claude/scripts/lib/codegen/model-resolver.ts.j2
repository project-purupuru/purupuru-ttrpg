// --- Pre-resolution validation (stage 0 — IMP-004) -----------------------

function preValidate(mergedConfig: MergedConfig): ResolutionError | null {
    const operator = (mergedConfig.operator_config || {}) as Record<string, unknown>;
    const framework = (mergedConfig.framework_defaults || {}) as Record<string, unknown>;

    const extra = (operator.model_aliases_extra || {}) as Record<string, unknown>;
    const override = (operator.model_aliases_override || {}) as Record<string, unknown>;

    // IMP-004: same id in both extra AND override is mutually exclusive.
    const extraKeys = Object.keys(extra).sort();
    const collisions: string[] = [];
    for (const k of extraKeys) {
        if (hasKey(override, k)) collisions.push(k);
    }
    if (collisions.length > 0) {
        return {
            code: ERR_EXTRA_OVERRIDE_CONFLICT,
            stage_failed: 0,
            detail: `id \`${collisions[0]}\` appears in BOTH model_aliases_extra and model_aliases_override; mutually exclusive at entry level (IMP-004)`,
        };
    }

    // IMP-004: model_aliases_override must target a known framework id.
    const providers = (framework.providers || {}) as Record<string, unknown>;
    const frameworkModels = new Set<string>();
    if (typeof providers === "object" && providers !== null && !Array.isArray(providers)) {
        for (const provData of Object.values(providers)) {
            if (provData === null || typeof provData !== "object" || Array.isArray(provData)) continue;
            const models = (provData as Record<string, unknown>).models;
            if (models !== null && typeof models === "object" && !Array.isArray(models)) {
                for (const k of Object.keys(models as Record<string, unknown>)) {
                    frameworkModels.add(k);
                }
            }
        }
    }
    const overrideKeys = Object.keys(override).sort();
    for (const overrideId of overrideKeys) {
        if (!frameworkModels.has(overrideId)) {
            return {
                code: ERR_OVERRIDE_UNKNOWN,
                stage_failed: 0,
                detail: `model_aliases_override targets \`${overrideId}\` which is not a framework-default ID`,
            };
        }
    }
    return null;
}

// --- Stage helpers --------------------------------------------------------

interface StageHit {
    resolved_provider?: string;
    resolved_model_id?: string;
    stage_entry: StageOutcome;
    tier_for_cascade?: string;
    error?: ResolutionError;
    is_legacy?: boolean;
}

/** S1: explicit `provider:model_id` pin in skill_models. */
function stage1ExplicitPin(skillModelsValue: unknown): StageHit | null {
    if (typeof skillModelsValue !== "string") return null;
    if (!skillModelsValue.includes(":")) return null;
    const colonIdx = skillModelsValue.indexOf(":");
    const provider = skillModelsValue.slice(0, colonIdx);
    const model_id = skillModelsValue.slice(colonIdx + 1);
    if (!provider || !model_id) return null;
    return {
        resolved_provider: provider,
        resolved_model_id: model_id,
        stage_entry: {
            stage: 1,
            outcome: "hit",
            label: STAGE1_LABEL,
            details: { pin: skillModelsValue },
        },
    };
}

/** S2: tag in skill_models — direct alias hit OR cascade-to-S3. */
function stage2SkillModels(
    skillModelsValue: unknown,
    operatorTierMappings: Record<string, unknown>,
    frameworkTierMappings: Record<string, unknown>,
    frameworkAliases: Record<string, unknown>,
    operatorExtra: Record<string, unknown>,
): StageHit | null {
    if (typeof skillModelsValue !== "string") return null;
    if (skillModelsValue.includes(":")) return null;  // S1 path

    const val = skillModelsValue;
    const stageEntry: StageOutcome = {
        stage: 2,
        outcome: "hit",
        label: STAGE2_LABEL,
        details: { alias: val },
    };

    const isTier =
        TIER_NAMES.has(val) ||
        hasKey(operatorTierMappings, val) ||
        hasKey(frameworkTierMappings, val);

    // Tier-tag path (also IMP-007 collision case)
    if (isTier) {
        return { stage_entry: stageEntry, tier_for_cascade: val };
    }

    // Direct alias path — framework_aliases first, then model_aliases_extra
    const aliasEntry = lookupAlias(frameworkAliases, val);
    if (aliasEntry !== null) {
        return {
            resolved_provider: aliasEntry.provider,
            resolved_model_id: aliasEntry.model_id,
            stage_entry: stageEntry,
        };
    }
    if (hasKey(operatorExtra, val)) {
        const extraEntry = normalizeAliasEntry(operatorExtra[val]);
        if (extraEntry !== null) {
            return {
                resolved_provider: extraEntry.provider,
                resolved_model_id: extraEntry.model_id,
                stage_entry: stageEntry,
            };
        }
    }

    // Unknown — cascade (S3 will likely emit [TIER-NO-MAPPING])
    return { stage_entry: stageEntry, tier_for_cascade: val };
}

/** S3: tier_groups.mappings lookup (operator first, then framework). */
function stage3TierGroups(
    tier: string,
    operatorTierMappings: Record<string, unknown>,
    frameworkTierMappings: Record<string, unknown>,
    frameworkAliases: Record<string, unknown>,
    operatorExtra: Record<string, unknown>,
): StageHit {
    // gp CRIT-2 (sprint-2D.c review): mirror Python's `or` truthy short-
    // circuit. An operator mapping that exists but is empty `{}` is falsy
    // in Python; the resolver falls through to the framework default.
    // TS must replicate: an empty-dict-valued key counts as "no mapping".
    let mapping: Record<string, unknown> | null = null;
    if (hasKey(operatorTierMappings, tier)) {
        const v = operatorTierMappings[tier];
        if (v !== null && typeof v === "object" && !Array.isArray(v) &&
            Object.keys(v as Record<string, unknown>).length > 0) {
            mapping = v as Record<string, unknown>;
        }
    }
    if (mapping === null && hasKey(frameworkTierMappings, tier)) {
        const v = frameworkTierMappings[tier];
        if (v !== null && typeof v === "object" && !Array.isArray(v) &&
            Object.keys(v as Record<string, unknown>).length > 0) {
            mapping = v as Record<string, unknown>;
        }
    }
    if (mapping === null) {
        return {
            stage_entry: { stage: 3, outcome: "error", label: STAGE3_LABEL },
            error: {
                code: ERR_TIER_NO_MAPPING,
                stage_failed: 3,
                detail: `tier \`${tier}\` has no mapping for any provider; configure tier_groups.mappings or use explicit alias`,
            },
        };
    }

    // Pick deterministically — sorted provider keys, take first
    const providers = Object.keys(mapping).sort();
    if (providers.length === 0) {
        return {
            stage_entry: { stage: 3, outcome: "error", label: STAGE3_LABEL },
            error: {
                code: ERR_TIER_NO_MAPPING,
                stage_failed: 3,
                detail: `tier \`${tier}\` has no mapping for any provider; configure tier_groups.mappings or use explicit alias`,
            },
        };
    }
    const provider = providers[0];
    const alias = mapping[provider];
    if (typeof alias !== "string" || !alias) {
        return {
            stage_entry: { stage: 3, outcome: "error", label: STAGE3_LABEL },
            error: {
                code: ERR_TIER_NO_MAPPING,
                stage_failed: 3,
                detail: `tier \`${tier}\` mapped but provider \`${provider}\` has no alias`,
            },
        };
    }

    const aliasEntry = lookupAlias(frameworkAliases, alias);
    if (aliasEntry === null) {
        return {
            stage_entry: { stage: 3, outcome: "error", label: STAGE3_LABEL },
            error: {
                code: ERR_TIER_NO_MAPPING,
                stage_failed: 3,
                detail: `tier \`${tier}\` mapped to alias \`${alias}\` for provider \`${provider}\` but alias not found in framework_defaults.aliases`,
            },
        };
    }

    const details: Record<string, unknown> = { resolved_alias: alias };
    if (hasKey(operatorExtra, tier)) {
        // IMP-007: tier-tag name collides with model_aliases_extra entry of
        // the same name. Tier-tag wins; report the collision.
        details.alias_collides_with_tier = true;
    }
    return {
        resolved_provider: aliasEntry.provider,
        resolved_model_id: aliasEntry.model_id,
        stage_entry: {
            stage: 3,
            outcome: "hit",
            label: STAGE3_LABEL,
            details,
        },
    };
}

/** S4: legacy shape `<skill>.models.<role>: <alias>` with deprecation warning. */
function stage4LegacyShape(
    operatorConfig: Record<string, unknown>,
    skill: string,
    role: string,
    frameworkAliases: Record<string, unknown>,
): StageHit | null {
    if (!hasKey(operatorConfig, skill)) return null;
    const skillBlock = operatorConfig[skill];
    if (skillBlock === null || typeof skillBlock !== "object" || Array.isArray(skillBlock)) return null;
    const sb = skillBlock as Record<string, unknown>;
    const legacyModels = sb.models;
    if (legacyModels === null || typeof legacyModels !== "object" || Array.isArray(legacyModels)) return null;
    const lm = legacyModels as Record<string, unknown>;
    if (!hasKey(lm, role)) return null;
    const alias = lm[role];
    if (typeof alias !== "string") return null;
    const aliasEntry = lookupAlias(frameworkAliases, alias);
    if (aliasEntry === null) return null;  // Fall through to S5 per FR-3.7
    return {
        resolved_provider: aliasEntry.provider,
        resolved_model_id: aliasEntry.model_id,
        is_legacy: true,
        stage_entry: {
            stage: 4,
            outcome: "hit",
            label: STAGE4_LABEL,
            details: { warning: "[LEGACY-SHAPE-DEPRECATED]" },
        },
    };
}

/** S5: framework default for skill via `agents.<skill>.{model,default_tier}`. */
function stage5FrameworkDefault(
    frameworkDefaults: Record<string, unknown>,
    skill: string,
    frameworkAliases: Record<string, unknown>,
    frameworkTierMappings: Record<string, unknown>,
    runtimeState: Record<string, unknown>,
): StageHit | null {
    const agents = frameworkDefaults.agents;
    if (agents === null || agents === undefined || typeof agents !== "object" || Array.isArray(agents)) return null;
    const agentsRec = agents as Record<string, unknown>;
    if (!hasKey(agentsRec, skill)) return null;
    const agent = agentsRec[skill];
    if (agent === null || typeof agent !== "object" || Array.isArray(agent)) return null;
    const ag = agent as Record<string, unknown>;

    const isDegraded = runtimeState.overlay_state === "degraded";
    const baseDetails: Record<string, unknown> = {};
    if (isDegraded) {
        baseDetails.source = "degraded_cache";
    }

    // Try direct .model first
    const modelAlias = ag.model;
    if (typeof modelAlias === "string") {
        const aliasEntry = lookupAlias(frameworkAliases, modelAlias);
        if (aliasEntry !== null) {
            const details: Record<string, unknown> = { ...baseDetails, alias: modelAlias };
            return {
                resolved_provider: aliasEntry.provider,
                resolved_model_id: aliasEntry.model_id,
                stage_entry: {
                    stage: 5,
                    outcome: "hit",
                    label: STAGE5_LABEL,
                    details,
                },
            };
        }
    }

    // Fall back to default_tier
    const defaultTier = ag.default_tier;
    if (typeof defaultTier !== "string") return null;

    // Try tier_groups.mappings.<tier> first
    if (hasKey(frameworkTierMappings, defaultTier)) {
        const mapping = frameworkTierMappings[defaultTier];
        if (mapping !== null && typeof mapping === "object" && !Array.isArray(mapping)) {
            const m = mapping as Record<string, unknown>;
            const providers = Object.keys(m).sort();
            if (providers.length > 0) {
                const provider = providers[0];
                const alias = m[provider];
                if (typeof alias === "string" && alias) {
                    const aliasEntry = lookupAlias(frameworkAliases, alias);
                    if (aliasEntry !== null) {
                        const details: Record<string, unknown> = { ...baseDetails, alias };
                        return {
                            resolved_provider: aliasEntry.provider,
                            resolved_model_id: aliasEntry.model_id,
                            stage_entry: {
                                stage: 5,
                                outcome: "hit",
                                label: STAGE5_LABEL,
                                details,
                            },
                        };
                    }
                }
            }
        }
    }

    // Permissive fallback: direct alias by tier name
    const aliasEntry = lookupAlias(frameworkAliases, defaultTier);
    if (aliasEntry !== null) {
        const details: Record<string, unknown> = { ...baseDetails, alias: defaultTier };
        return {
            resolved_provider: aliasEntry.provider,
            resolved_model_id: aliasEntry.model_id,
            stage_entry: {
                stage: 5,
                outcome: "hit",
                label: STAGE5_LABEL,
                details,
            },
        };
    }
    return null;
}

interface Stage6Outcome {
    stage_entry: StageOutcome;
    resolved_provider?: string;
    resolved_model_id?: string;
}

/** S6: prefer_pro_models overlay (gated per FR-3.4 for legacy shapes). */
function stage6PreferPro(
    resolvedAlias: string | null,
    operatorConfig: Record<string, unknown>,
    frameworkAliases: Record<string, unknown>,
    isLegacyPath: boolean,
    skill: string | null,
): Stage6Outcome | null {
    const preferPro = operatorConfig.prefer_pro_models === true;
    if (!preferPro) return null;

    if (isLegacyPath) {
        // gp HIGH-1: per PRD FR-3.4, `respect_prefer_pro` is per-skill.
        let respect = false;
        if (skill !== null && hasKey(operatorConfig, skill)) {
            const sb = operatorConfig[skill];
            if (sb !== null && typeof sb === "object" && !Array.isArray(sb)) {
                respect = (sb as Record<string, unknown>).respect_prefer_pro === true;
            }
        }
        if (!respect) {
            return {
                stage_entry: {
                    stage: 6,
                    outcome: "skipped",
                    label: STAGE6_LABEL,
                    details: { reason: "legacy_shape_without_respect_prefer_pro" },
                },
            };
        }
    }

    if (resolvedAlias === null) {
        return {
            stage_entry: {
                stage: 6,
                outcome: "skipped",
                label: STAGE6_LABEL,
                details: { reason: "no_alias_to_overlay" },
            },
        };
    }

    const proAlias = `${resolvedAlias}-pro`;
    const proEntry = lookupAlias(frameworkAliases, proAlias);
    if (proEntry === null) {
        return {
            stage_entry: {
                stage: 6,
                outcome: "skipped",
                label: STAGE6_LABEL,
                details: { reason: "no_pro_variant_for_alias", alias: resolvedAlias },
            },
        };
    }

    return {
        resolved_provider: proEntry.provider,
        resolved_model_id: proEntry.model_id,
        stage_entry: {
            stage: 6,
            outcome: "applied",
            label: STAGE6_LABEL,
            details: { from: resolvedAlias, to: proAlias },
        },
    };
}

// --- Public API -----------------------------------------------------------

/**
 * Resolve (skill, role) against merged_config per FR-3.9 6 stages.
 *
 * Pure function. No I/O, no env access, no state. Mirrors Python's
 * `model_resolver.resolve` byte-for-byte on canonical-JSON output.
 */
export function resolve(mergedConfig: MergedConfig, skill: string, role: string): ResolutionResult {
    // gp CRIT-1 (sprint-2D.c review): canonicalize input BEFORE any helper
    // sees it. Mirrors Python's `_canonicalize_dict_keys(merged_config)` at
    // resolve() entry. Defense-in-depth — JSON.parse always gives string
    // keys, but a programmatic caller could construct a non-string-keyed
    // map; the recursive sort + Object.create(null) walk forecloses any
    // iteration-order divergence with Python that V8 currently happens to
    // mask.
    const cfg = canonicalizeRecursive(mergedConfig) as MergedConfig;

    // Cypherpunk HIGH-2: reject inputs with C0 control bytes BEFORE any
    // helper sees them.
    if (hasCtrlByte(cfg)) {
        return {
            skill,
            role,
            error: {
                code: ERR_INPUT_CONTROL_BYTE,
                stage_failed: 0,
                detail: "input contains a C0 control byte (0x00-0x08, 0x0B-0x1F) in a string scalar; refuse to resolve",
            },
        };
    }

    // Stage 0: pre-validation
    const preErr = preValidate(mergedConfig);
    if (preErr !== null) {
        return { skill, role, error: preErr };
    }

    const operatorConfig = (mergedConfig.operator_config || {}) as Record<string, unknown>;
    const frameworkDefaults = (mergedConfig.framework_defaults || {}) as Record<string, unknown>;
    const runtimeState = (mergedConfig.runtime_state || {}) as Record<string, unknown>;
    const frameworkAliases = (frameworkDefaults.aliases || {}) as Record<string, unknown>;
    const frameworkTierGroups = (frameworkDefaults.tier_groups || {}) as Record<string, unknown>;
    const frameworkTierMappings = (frameworkTierGroups.mappings || {}) as Record<string, unknown>;
    const operatorTierGroups = (operatorConfig.tier_groups || {}) as Record<string, unknown>;
    const operatorTierMappings = (operatorTierGroups.mappings || {}) as Record<string, unknown>;
    const operatorExtra = (operatorConfig.model_aliases_extra || {}) as Record<string, unknown>;

    const skillModels = (operatorConfig.skill_models || {}) as Record<string, unknown>;
    let skillValue: unknown = undefined;
    if (hasKey(skillModels, skill)) {
        const block = skillModels[skill];
        if (block !== null && typeof block === "object" && !Array.isArray(block)) {
            skillValue = (block as Record<string, unknown>)[role];
        }
    }

    const resolutionPath: StageOutcome[] = [];
    let finalProvider: string | undefined;
    let finalModelId: string | undefined;

    // S1: explicit pin
    const s1 = stage1ExplicitPin(skillValue);
    if (s1 !== null) {
        resolutionPath.push(s1.stage_entry);
        finalProvider = s1.resolved_provider;
        finalModelId = s1.resolved_model_id;
        const s6 = stage6PreferPro(null, operatorConfig, frameworkAliases, false, skill);
        if (s6 !== null) {
            resolutionPath.push(s6.stage_entry);
            if (s6.resolved_provider !== undefined) {
                finalProvider = s6.resolved_provider;
                finalModelId = s6.resolved_model_id;
            }
        }
        return {
            skill, role,
            resolved_provider: finalProvider!,
            resolved_model_id: finalModelId!,
            resolution_path: resolutionPath,
        };
    }

    // S2 (+ optional S3 cascade)
    const s2 = stage2SkillModels(
        skillValue,
        operatorTierMappings,
        frameworkTierMappings,
        frameworkAliases,
        operatorExtra,
    );
    if (s2 !== null) {
        resolutionPath.push(s2.stage_entry);
        if (s2.resolved_provider !== undefined) {
            // Direct alias hit at S2 — no cascade
            finalProvider = s2.resolved_provider;
            finalModelId = s2.resolved_model_id;
            const aliasForOverlay = (s2.stage_entry.details?.alias as string | undefined) ?? null;
            const s6 = stage6PreferPro(aliasForOverlay, operatorConfig, frameworkAliases, false, skill);
            if (s6 !== null) {
                resolutionPath.push(s6.stage_entry);
                if (s6.resolved_provider !== undefined) {
                    finalProvider = s6.resolved_provider;
                    finalModelId = s6.resolved_model_id;
                }
            }
            return {
                skill, role,
                resolved_provider: finalProvider!,
                resolved_model_id: finalModelId!,
                resolution_path: resolutionPath,
            };
        }
        // Cascade to S3
        const tier = s2.tier_for_cascade!;
        const s3 = stage3TierGroups(
            tier,
            operatorTierMappings,
            frameworkTierMappings,
            frameworkAliases,
            operatorExtra,
        );
        if (s3.error !== undefined) {
            return { skill, role, error: s3.error };
        }
        resolutionPath.push(s3.stage_entry);
        finalProvider = s3.resolved_provider;
        finalModelId = s3.resolved_model_id;
        const aliasForOverlay = (s3.stage_entry.details?.resolved_alias as string | undefined) ?? null;
        const s6 = stage6PreferPro(aliasForOverlay, operatorConfig, frameworkAliases, false, skill);
        if (s6 !== null) {
            resolutionPath.push(s6.stage_entry);
            if (s6.resolved_provider !== undefined) {
                finalProvider = s6.resolved_provider;
                finalModelId = s6.resolved_model_id;
            }
        }
        return {
            skill, role,
            resolved_provider: finalProvider!,
            resolved_model_id: finalModelId!,
            resolution_path: resolutionPath,
        };
    }

    // S4: legacy shape
    const s4 = stage4LegacyShape(operatorConfig, skill, role, frameworkAliases);
    if (s4 !== null) {
        resolutionPath.push(s4.stage_entry);
        finalProvider = s4.resolved_provider;
        finalModelId = s4.resolved_model_id;
        // Recover legacy alias from operator_config[skill].models[role]
        let legacyAlias: string | null = null;
        if (hasKey(operatorConfig, skill)) {
            const sb = operatorConfig[skill];
            if (sb !== null && typeof sb === "object" && !Array.isArray(sb)) {
                const m = (sb as Record<string, unknown>).models;
                if (m !== null && typeof m === "object" && !Array.isArray(m)) {
                    const v = (m as Record<string, unknown>)[role];
                    if (typeof v === "string") legacyAlias = v;
                }
            }
        }
        const s6 = stage6PreferPro(legacyAlias, operatorConfig, frameworkAliases, true, skill);
        if (s6 !== null) {
            resolutionPath.push(s6.stage_entry);
            if (s6.resolved_provider !== undefined) {
                finalProvider = s6.resolved_provider;
                finalModelId = s6.resolved_model_id;
            }
        }
        return {
            skill, role,
            resolved_provider: finalProvider!,
            resolved_model_id: finalModelId!,
            resolution_path: resolutionPath,
        };
    }

    // S5: framework default
    const s5 = stage5FrameworkDefault(
        frameworkDefaults, skill, frameworkAliases, frameworkTierMappings, runtimeState,
    );
    if (s5 !== null) {
        resolutionPath.push(s5.stage_entry);
        finalProvider = s5.resolved_provider;
        finalModelId = s5.resolved_model_id;
        const aliasForOverlay = (s5.stage_entry.details?.alias as string | undefined) ?? null;
        const s6 = stage6PreferPro(aliasForOverlay, operatorConfig, frameworkAliases, false, skill);
        if (s6 !== null) {
            resolutionPath.push(s6.stage_entry);
            if (s6.resolved_provider !== undefined) {
                finalProvider = s6.resolved_provider;
                finalModelId = s6.resolved_model_id;
            }
        }
        return {
            skill, role,
            resolved_provider: finalProvider!,
            resolved_model_id: finalModelId!,
            resolution_path: resolutionPath,
        };
    }

    // All stages exhausted — fail-closed
    return {
        skill, role,
        error: {
            code: ERR_NO_RESOLUTION,
            stage_failed: 5,
            detail: `no resolution for skill \`${skill}\` role \`${role}\`; check skill_models, legacy shape, and agents.${skill} default`,
        },
    };
}
