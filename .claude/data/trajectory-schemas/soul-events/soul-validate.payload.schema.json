{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0xhoneyjar.dev/loa/schemas/soul-events/soul-validate.payload.schema.json",
  "title": "L7 soul.validate Payload",
  "description": "Audit-event payload for an L7 SOUL.md operator-time validation. cycle-098 Sprint 7. Per SDD §5.9.2 the CLI itself emits no audit log; this payload exists for callers (e.g., CI gates, /ride consistency checks) that DO want to record validate runs.",
  "type": "object",
  "required": [
    "file_path",
    "schema_mode",
    "outcome"
  ],
  "additionalProperties": false,
  "properties": {
    "file_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "maxLength": 16
    },
    "schema_mode": {
      "type": "string",
      "enum": ["strict", "warn"]
    },
    "outcome": {
      "type": "string",
      "enum": ["valid", "warn", "invalid", "file-missing"]
    },
    "missing_required_sections": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9 _-]{1,64}$"
      }
    },
    "prescriptive_section_hits": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9 _-]{1,64}$"
      }
    },
    "frontmatter_errors": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string",
        "maxLength": 256
      }
    }
  }
}
