{
  "name": "@loa/bridgebuilder-review",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Autonomous PR review skill for Loa framework",
  "exports": {
    ".": "./dist/main.js",
    "./ports": "./dist/ports/index.js",
    "./core": "./dist/core/index.js",
    "./adapters": "./dist/adapters/index.js"
  },
  "scripts": {
    "build": "npm run gen-bb-registry && cd resources && npx tsc --project tsconfig.json && cd ../../../.. && tools/check-bb-dist-fresh.sh --write-manifest",
    "build:manifest": "../../../tools/check-bb-dist-fresh.sh --write-manifest",
    "build:check": "../../../tools/check-bb-dist-fresh.sh --check",
    "gen-bb-registry": "npx tsx scripts/gen-bb-registry.ts",
    "gen-bb-registry:check": "npx tsx scripts/gen-bb-registry.ts --check",
    "test": "cd resources && npx tsx --test __tests__/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
