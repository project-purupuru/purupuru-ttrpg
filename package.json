{
  "name": "purupuru-ttrpg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "bash scripts/prebuild-honeycomb.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:world": "bash scripts/check-world-discipline.sh",
    "check:world:selftest": "bash scripts/check-world-discipline.selftest.sh",
    "check:honeycomb": "bash scripts/check-honeycomb-discipline.sh",
    "check:honeycomb:selftest": "bash scripts/check-honeycomb-discipline.selftest.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:battle-v2": "PLAYWRIGHT_PORT=3000 playwright test tests/e2e/battle-v2.spec.ts --project=chromium",
    "assets:scan": "node app/battle-v2/_devtools/scripts/scan-media.mjs",
    "hounfour:drift": "tsx scripts/hounfour-drift.ts",
    "test:types": "pnpm typecheck",
    "s0:preflight": "tsx scripts/s0-preflight-harness.ts",
    "s0:spike": "tsx scripts/s0-spike-ajv-element-wood.ts",
    "content:validate": "tsx scripts/validate-content.ts",
    "substrate:check": "bash scripts/check-single-runtime.sh && bash scripts/check-world-discipline.sh && bash scripts/check-purupuru-discipline.sh && pnpm content:validate && vitest run lib/purupuru"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@dialectlabs/blinks": "^0.22.5",
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@phosphor-icons/react": "^2.1.10",
    "@purupuru/medium-blink": "workspace:*",
    "@purupuru/peripheral-events": "workspace:*",
    "@purupuru/world-sources": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.95.0",
    "@types/js-yaml": "^4.0.9",
    "@vercel/kv": "^3.0.0",
    "agentation": "^3.0.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "effect": "^3.10.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "pixi.js": "^8.18.1",
    "postprocessing": "^6.39.1",
    "react": "19.2.6",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "expect-type": "^1.3.0",
    "jsdom": "^29.1.1",
    "json-schema-diff": "^1.0.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
