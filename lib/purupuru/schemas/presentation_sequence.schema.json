{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://purupuru.dev/schemas/presentation_sequence.schema.json",
  "title": "Purupuru Presentation Sequence",
  "description": "Choreographed view/audio/VFX sequence that consumes semantic events but cannot mutate game state.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "packId",
    "category",
    "triggerEvents",
    "inputPolicy",
    "interruptPolicy",
    "saliencyBudget",
    "requiredAnchors",
    "mutatesGameState",
    "beats"
  ],
  "additionalProperties": false,
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "minLength": 2,
      "maxLength": 96
    },
    "locKey": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "minLength": 2,
      "maxLength": 128
    },
    "elementId": {
      "type": "string",
      "enum": [
        "wood",
        "fire",
        "water",
        "metal",
        "earth"
      ]
    },
    "oklch": {
      "type": "string",
      "pattern": "^oklch\\([0-9.]+\\s+[0-9.]+\\s+[0-9.]+(?:\\s*/\\s*[0-9.]+)?\\)$"
    },
    "saliencyTier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "approvalTier": {
      "type": "string",
      "enum": [
        "core",
        "official",
        "community_safe",
        "experimental",
        "locked"
      ]
    },
    "beatAction": {
      "type": "string",
      "enum": [
        "wait",
        "set_ui_state",
        "play_vfx",
        "start_vfx_loop",
        "stop_vfx_loop",
        "play_audio",
        "animate_actor",
        "move_along_spline",
        "set_zone_visual_state",
        "camera_pulse",
        "emit_presentation_event",
        "lock_input",
        "unlock_input",
        "show_reward_preview",
        "set_saliency_tier"
      ]
    }
  },
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "$ref": "#/$defs/stableId"
    },
    "packId": {
      "$ref": "#/$defs/stableId"
    },
    "category": {
      "type": "string",
      "enum": [
        "card_activation",
        "zone_event",
        "ui_transition",
        "daemon_reaction",
        "weather_transition",
        "reward_reveal"
      ]
    },
    "triggerEvents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Za-z0-9]+$"
      }
    },
    "inputPolicy": {
      "type": "object",
      "required": [
        "lockMode",
        "maxLockMs"
      ],
      "additionalProperties": false,
      "properties": {
        "lockMode": {
          "type": "string",
          "enum": [
            "none",
            "soft",
            "hard"
          ]
        },
        "maxLockMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "lockOwnerId": {
          "$ref": "#/$defs/stableId"
        }
      }
    },
    "interruptPolicy": {
      "type": "object",
      "required": [
        "skippable",
        "cancelable",
        "fastForwardable"
      ],
      "additionalProperties": false,
      "properties": {
        "skippable": {
          "type": "boolean"
        },
        "cancelable": {
          "type": "boolean"
        },
        "fastForwardable": {
          "type": "boolean"
        },
        "onInterrupt": {
          "type": "string",
          "enum": [
            "finish_to_end_state",
            "cancel_to_idle",
            "transfer_to_next_sequence"
          ]
        }
      }
    },
    "saliencyBudget": {
      "type": "object",
      "required": [
        "primaryTier",
        "secondaryTier",
        "maxSimultaneousTier5",
        "maxAmbientTier"
      ],
      "additionalProperties": false,
      "properties": {
        "primaryTier": {
          "$ref": "#/$defs/saliencyTier"
        },
        "secondaryTier": {
          "$ref": "#/$defs/saliencyTier"
        },
        "maxSimultaneousTier5": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "maxAmbientTier": {
          "$ref": "#/$defs/saliencyTier"
        }
      }
    },
    "requiredAnchors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stableId"
      }
    },
    "mutatesGameState": {
      "type": "boolean",
      "const": false
    },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "atMs",
          "durationMs",
          "action",
          "target",
          "params"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/$defs/stableId"
          },
          "atMs": {
            "type": "integer",
            "minimum": 0
          },
          "durationMs": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "action": {
            "$ref": "#/$defs/beatAction"
          },
          "target": {
            "type": "string"
          },
          "params": {
            "type": "object"
          },
          "requiresAnchors": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/stableId"
            }
          },
          "saliencyTier": {
            "$ref": "#/$defs/saliencyTier"
          }
        }
      }
    }
  }
}
