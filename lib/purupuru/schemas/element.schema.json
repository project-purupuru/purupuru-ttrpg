{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://purupuru.dev/schemas/element.schema.json",
  "title": "Purupuru Element Profile",
  "description": "Defines the mechanical and presentation grammar for a core element.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "nameKey",
    "verbs",
    "colorTokens",
    "motifs",
    "vfxGrammar",
    "audioGrammar",
    "constraints"
  ],
  "additionalProperties": false,
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "minLength": 2,
      "maxLength": 96
    },
    "locKey": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "minLength": 2,
      "maxLength": 128
    },
    "elementId": {
      "type": "string",
      "enum": [
        "wood",
        "fire",
        "water",
        "metal",
        "earth"
      ]
    },
    "oklch": {
      "type": "string",
      "pattern": "^oklch\\([0-9.]+\\s+[0-9.]+\\s+[0-9.]+(?:\\s*/\\s*[0-9.]+)?\\)$"
    },
    "saliencyTier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "approvalTier": {
      "type": "string",
      "enum": [
        "core",
        "official",
        "community_safe",
        "experimental",
        "locked"
      ]
    }
  },
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "$ref": "#/$defs/elementId"
    },
    "nameKey": {
      "$ref": "#/$defs/locKey"
    },
    "summaryKey": {
      "$ref": "#/$defs/locKey"
    },
    "verbs": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+$"
      }
    },
    "colorTokens": {
      "type": "object",
      "required": [
        "primary",
        "muted",
        "glow",
        "weather"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/oklch"
      },
      "properties": {
        "primary": {
          "$ref": "#/$defs/oklch"
        },
        "muted": {
          "$ref": "#/$defs/oklch"
        },
        "glow": {
          "$ref": "#/$defs/oklch"
        },
        "weather": {
          "$ref": "#/$defs/oklch"
        },
        "ink": {
          "$ref": "#/$defs/oklch"
        }
      }
    },
    "motifs": {
      "type": "object",
      "required": [
        "shape",
        "worldProps",
        "shrineRelief",
        "daemonSilhouette"
      ],
      "additionalProperties": false,
      "properties": {
        "shape": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "worldProps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "shrineRelief": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "daemonSilhouette": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "vfxGrammar": {
      "type": "object",
      "required": [
        "travel",
        "impact",
        "localizedWeather",
        "afterglow",
        "prohibited"
      ],
      "additionalProperties": false,
      "properties": {
        "travel": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "impact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "localizedWeather": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "afterglow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "audioGrammar": {
      "type": "object",
      "required": [
        "material",
        "motion",
        "impact",
        "ambient"
      ],
      "additionalProperties": false,
      "properties": {
        "material": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "motion": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "impact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ambient": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "required": [
        "localizedWeatherOnlyByDefault",
        "maxAmbientSaliency",
        "requiresNamedAnchors"
      ],
      "additionalProperties": false,
      "properties": {
        "localizedWeatherOnlyByDefault": {
          "type": "boolean",
          "const": true
        },
        "maxAmbientSaliency": {
          "$ref": "#/$defs/saliencyTier"
        },
        "requiresNamedAnchors": {
          "type": "boolean",
          "const": true
        },
        "shouldNotFeelLike": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/elementId"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
